// Ginkgo_bioworks clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace ginkgo_bioworks {

    entity Strain {
        id: string @unique
        name: string
        organism: string
        genotype: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Construct {
        id: string @unique
        name: string
        vector: string
        insertRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Sequence {
        id: string @unique
        constructId: string
        length: integer
        checksum: string
        dataRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Assay {
        id: string @unique
        strainId: string
        type: string
        readout: string
        value: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Sample {
        id: string @unique
        strainId: string
        barcode: string
        volumeUl: float
        location: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Workflow {
        id: string @unique
        name: string
        protocolRef: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
